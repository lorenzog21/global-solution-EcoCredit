{
  "info": {
    "name": "EcoCredit API",
    "description": "Carbon Compliance SaaS — FIAP Global Solution 2026/1",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api/v1" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "TC-01: Login válido",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Retorna token', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.token).to.be.a('string');",
                  "  pm.collectionVariables.set('token', body.token);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"admin@petro.com\", \"password\": \"Admin@2026\"}"
            }
          }
        },
        {
          "name": "TC-02: Login inválido",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));",
                  "pm.test('Mensagem genérica', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.error).to.equal('Credenciais inválidas.');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"admin@petro.com\", \"password\": \"errada\"}"
            }
          }
        }
      ]
    },
    {
      "name": "Facilities",
      "item": [
        {
          "name": "TC-06: GET sem token (401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 401', () => pm.response.to.have.status(401));"]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/facilities"
          }
        },
        {
          "name": "GET instalações autenticado",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/facilities",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Emissions",
      "item": [
        {
          "name": "TC-03: Registrar emissão válida",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 201', () => pm.response.to.have.status(201));"]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/emissions",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"facilityId\": \"fac-001\", \"gasType\": \"CO2\", \"quantityTco2e\": 42.7, \"source\": \"IOT_SENSOR\", \"sensorId\": \"sensor-co2-fac-001\", \"rawPpm\": 1087.5}"
            }
          }
        },
        {
          "name": "TC-04: Emissão quantidade negativa",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 400', () => pm.response.to.have.status(400));"]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/emissions",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"facilityId\": \"fac-001\", \"gasType\": \"CO2\", \"quantityTco2e\": -10, \"source\": \"MANUAL\"}"
            }
          }
        },
        {
          "name": "GET Sumário de emissões",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/emissions/summary",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Credits",
      "item": [
        {
          "name": "GET créditos da empresa",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/credits",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Alerts",
      "item": [
        {
          "name": "GET alertas ativos",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/alerts",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    }
  ]
}
